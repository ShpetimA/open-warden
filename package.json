{
  "name": "open-warden",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "dev": "turbo run dev --filter=desktop",
    "dev:electron": "pnpm --filter desktop dev:electron",
    "electron:dev": "pnpm --filter desktop electron:dev",
    "build": "turbo run build",
    "build:electron": "pnpm --filter desktop build:electron",
    "electron:build": "pnpm --filter desktop electron:build",
    "make:electron": "pnpm --filter desktop make:electron",
    "electron:make": "pnpm --filter desktop electron:make",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:e2e": "pnpm --filter desktop test:e2e",
    "test:e2e:install": "pnpm --filter desktop test:e2e:install",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "check": "pnpm lint && pnpm test && pnpm format:check"
  },
  "devDependencies": {
    "turbo": "^2.5.8"
  }
}
