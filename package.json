{
  "name": "open-warden",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "turbo run dev --filter=desktop",
    "dev:electron": "pnpm --filter desktop dev:electron",
    "electron:dev": "pnpm --filter desktop electron:dev",
    "build": "turbo run build",
    "build:electron": "pnpm --filter desktop build:electron",
    "electron:build": "pnpm --filter desktop electron:build",
    "make:electron": "pnpm --filter desktop make:electron",
    "electron:make": "pnpm --filter desktop electron:make",
    "lint": "oxlint --report-unused-disable-directives",
    "typecheck": "pnpm --filter desktop typecheck",
    "test": "turbo run test",
    "test:e2e": "pnpm --filter desktop test:e2e",
    "test:e2e:install": "pnpm --filter desktop test:e2e:install",
    "fmt": "oxfmt --ignore-path .oxfmtignore",
    "fmt:check": "oxfmt --check --ignore-path .oxfmtignore",
    "format": "pnpm fmt",
    "format:check": "pnpm fmt:check",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm fmt:check"
  },
  "devDependencies": {
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "turbo": "^2.5.8"
  },
  "packageManager": "pnpm@10.28.0"
}
