{
  "name": "desktop",
  "version": "0.0.0",
  "private": true,
  "description": "OpenWarden desktop app",
  "author": "OpenWarden",
  "type": "module",
  "main": ".vite/build/main.cjs",
  "scripts": {
    "clean:electron-build": "node -e \"require('node:fs').rmSync('.vite/build', { recursive: true, force: true })\"",
    "dev": "VITE_DESKTOP_FALLBACK=browser vite",
    "dev:renderer": "vite",
    "dev:electron": "pnpm run clean:electron-build && concurrently -k -n renderer,main,preload,electron -c auto \"pnpm run dev:renderer\" \"vite build --watch --config vite.main.config.ts\" \"vite build --watch --config vite.preload.config.ts\" \"node ./scripts/dev-electron.mjs\"",
    "electron:dev": "pnpm run dev:electron",
    "build": "pnpm run clean:electron-build && tsc -b && vite build && vite build --config vite.main.config.ts && vite build --config vite.preload.config.ts",
    "typecheck": "tsc --noEmit --pretty false -p tsconfig.app.json && tsc --noEmit --pretty false -p tsconfig.electron.json",
    "build:electron": "pnpm run build && electron-builder --config electron-builder.config.mjs --dir --publish never",
    "electron:build": "pnpm run build:electron",
    "make:electron": "pnpm run build && electron-builder --config electron-builder.config.mjs --publish never",
    "electron:make": "pnpm run make:electron",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install --with-deps chromium",
    "preview": "vite preview"
  },
  "dependencies": {
    "@base-ui/react": "^1.1.0",
    "@hookform/resolvers": "^5.2.2",
    "@m2d/react-markdown": "^1.0.0",
    "@pierre/diffs": "1.1.15",
    "@reduxjs/toolkit": "^2.9.0",
    "@tanstack/react-hotkeys": "^0.1.0",
    "@tanstack/react-pacer": "^0.20.0",
    "@tanstack/react-virtual": "^3.13.19",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.3",
    "electron-updater": "^6.6.2",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.563.0",
    "next-themes": "^0.4.6",
    "nuqs": "^2.8.9",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-day-picker": "^9.13.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.71.1",
    "react-redux": "^9.2.0",
    "react-resizable-panels": "^4.6.1",
    "react-router": "^7.13.0",
    "recharts": "2.15.4",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.0.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "^9.2.1",
    "electron": "41.0.2",
    "electron-builder": "^26.0.12",
    "jsdom": "^27.0.1",
    "shadcn": "^3.8.4",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "vite": "^7.2.4",
    "vitest": "^4.0.8",
    "wait-on": "^8.0.5"
  }
}
